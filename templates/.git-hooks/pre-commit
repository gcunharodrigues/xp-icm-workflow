#!/usr/bin/env bash
# xp-icm-workflow — pre-commit hook
#
# Enforce isolation entre workspace e src do projeto pai.
#
# IMPORTANTE: validacao de mensagem fica em .git/hooks/commit-msg
# (NAO aqui). Pre-commit roda ANTES de COMMIT_EDITMSG ser persistido,
# entao ler msg neste stage retorna a msg do commit ANTERIOR (bug
# original v1 do hook). Stages canonicos do git:
#   pre-commit  → file/atomicidade checks (sem msg)
#   commit-msg  → msg validation (recebe path em $1)
#
# Regras (R2.3, R3.3, R3.10, R5.4) — atualizadas em v3.4.0:
#
#   1. Skip durante rebase/merge em andamento.
#   2. Branches que nao casam ^workspace/[0-9]{3}- passam livremente.
#   3. Em branches workspace/NNN-slug:
#      a) Reject se algum staged file esta fora de workspaces/NNN-slug/
#         (whitelist v3.4.0: workspaces/.index.md, .gitignore, CLAUDE.md).
#         ADRs / docs/lessons.md / docs/tech_debt.md NAO estao no whitelist
#         desde v3.4.0 — devem ir via worktree linkada `.icm-main/`
#         (`cd .icm-main && git commit ...`). Doc: references/worktree-model.md.
#      c) Reject paths em `.icm-main/*` (worktree paths nao devem ser
#         tracked pelo workspace branch — gitignore deve cobrir).
#      b) Reject se outputs de stages/<NN>/output sao staged sem que
#         workspaces/NNN-slug/CONTEXT.md tambem esteja staged
#         (atomicidade L1 -> outputs: outputs exigem L1; L1 so
#         nao exige outputs — transicoes de estado podem nao produzir
#         outputs a cada commit).
#
# Anti-bypass: NUNCA use --no-verify; corrija o conteudo.

set -euo pipefail

# 1. Skip durante rebase/merge ------------------------------------------------

git_dir="$(git rev-parse --git-dir 2>/dev/null || echo .git)"
if [ -d "${git_dir}/rebase-merge" ] || [ -d "${git_dir}/rebase-apply" ]; then
    exit 0
fi

# 2. Detectar branch ----------------------------------------------------------

branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")"

# Branches que nao seguem padrao workspace/NNN-slug passam livremente.
if ! printf '%s' "$branch" | grep -Eq '^workspace/[0-9]{3}-'; then
    exit 0
fi

# 3. Extrair workspace ID e slug ----------------------------------------------

# branch = workspace/NNN-slug; extrair NNN e prefix completo NNN-slug
ws_full="${branch#workspace/}"          # NNN-slug
ws_id="${ws_full%%-*}"                  # NNN (3 digitos)
ws_dir="workspaces/${ws_full}"          # workspaces/NNN-slug

# 4. Coletar staged files -----------------------------------------------------

# --diff-filter=ACMR = adicionados, copiados, modificados, renomeados (nao deletados)
staged="$(git diff --cached --name-only --diff-filter=ACMR || true)"

if [ -z "$staged" ]; then
    # nada staged — nao temos o que validar; deixar git lidar
    exit 0
fi

# 5. Reject src edits (R3.3) --------------------------------------------------

offending=""
icm_main_offender=""
while IFS= read -r f; do
    [ -z "$f" ] && continue
    # `.icm-main/` worktree paths — esses sao da base branch (worktree linkada).
    # NAO devem aparecer no diff do workspace branch. Se aparecer, gitignore
    # quebrou ou alguem `git add`-ou na worktree errada.
    case "$f" in
        .icm-main/*)
            icm_main_offender="$f"
            break
            ;;
    esac
    # Whitelist v3.4.0: paths liberados fora de workspaces/NNN-slug/
    # ADRs / docs/lessons.md / docs/tech_debt.md NAO estao mais no whitelist —
    # commitam via `cd .icm-main && git commit ...` direto na base branch.
    case "$f" in
        workspaces/.index.md) continue ;;    # registry de workspaces
        .gitignore) continue ;;              # gitignore updates
        CLAUDE.md) continue ;;               # project root CLAUDE.md (G6) — dashboard ICM
    esac
    # Dentro do workspace? — liberado
    case "$f" in
        "${ws_dir}/"*) continue ;;
    esac
    # Caso contrario, fora de escopo
    offending="$f"
    break
done <<EOF
$staged
EOF

if [ -n "$icm_main_offender" ]; then
    cat >&2 <<EOM
ERROR: file '${icm_main_offender}' esta em .icm-main/ — diretorio reservado pra worktree linkada da base branch.
Worktree paths NAO devem ser tracked pelo workspace branch.
Verifique .gitignore (deve listar '.icm-main/').
Se quis commitar nessa pasta, use:
  cd .icm-main && git add <path-relativo> && git commit ...
NUNCA use --no-verify; corrija o conteudo.
EOM
    exit 1
fi

if [ -n "$offending" ]; then
    cat >&2 <<EOM
ERROR: branch workspace/${ws_full} pode tocar APENAS:
  - workspaces/${ws_full}/* (state files do workspace)
  - workspaces/.index.md (registry global)
  - .gitignore (regras de ignore)
  - CLAUDE.md (dashboard ICM no project root)
File offendor: ${offending}
Para tocar src/, docs/decisions/, docs/lessons.md, docs/tech_debt.md
ou demais paths da base branch, use a worktree linkada:
  cd .icm-main && git add <path> && git commit ...
NUNCA use --no-verify; corrija o conteudo.
EOM
    exit 1
fi

# 6. Atomicidade L1 <-> outputs -----------------------------------------------

# Se algum staged file esta em workspaces/NNN-slug/stages/<NN>/output/*,
# entao workspaces/NNN-slug/CONTEXT.md deve estar staged tambem.
output_offender=""
output_stage=""
context_md_path="${ws_dir}/CONTEXT.md"

context_staged=0
while IFS= read -r f; do
    if [ "$f" = "$context_md_path" ]; then
        context_staged=1
    fi
done <<EOF
$staged
EOF

while IFS= read -r f; do
    [ -z "$f" ] && continue
    case "$f" in
        "${ws_dir}/stages/"*/output/*)
            # Extrair NN de stages/NN/output/...
            rest="${f#${ws_dir}/stages/}"
            stage_n="${rest%%/*}"
            output_offender="$f"
            output_stage="$stage_n"
            break
            ;;
    esac
done <<EOF
$staged
EOF

if [ -n "$output_offender" ] && [ "$context_staged" -eq 0 ]; then
    cat >&2 <<EOM
ERROR: outputs do estagio ${output_stage} staged sem update de CONTEXT.md.
File: ${output_offender}
Atomicidade L1->outputs requerida. Stage CONTEXT.md tambem:
  git add ${context_md_path}

NUNCA use --no-verify; corrija o conteudo.
EOM
    exit 1
fi

# Tudo certo
exit 0
