{
  "_comment": "Example of project-root .claude/settings.local.json for skill xp-icm-workflow v3.6.1+. Copy to .claude/settings.local.json (gitignored). Replace <NNN-slug> with the active workspace. Commands use $CLAUDE_PROJECT_DIR (env var Claude Code exposes to the hook process) — cwd-independent, works even when session runs in .icm-main/ worktree or subdirectory. **tier=production extra:** adds a 4th entry in PreToolUse (matcher \"Bash\") with command bash \"$CLAUDE_PROJECT_DIR/workspaces/<NNN-slug>/.claude/hooks/block-dangerous-git.sh\" — blocks push --force, reset --hard, branch -D etc. Bootstrap auto-merge does this conditionally.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/workspaces/<NNN-slug>/.claude/hooks/icm-session-check.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "SlashCommand|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/workspaces/<NNN-slug>/.claude/hooks/block-init-during-icm.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/workspaces/<NNN-slug>/.claude/hooks/context-check.sh\""
          }
        ]
      }
    ]
  }
}
